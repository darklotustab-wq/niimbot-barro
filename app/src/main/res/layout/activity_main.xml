<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FFF8F0">

    <TextView
        android:text="📠 Niimbot Barro Tal Ves"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#8B3A0F"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="12dp"/>

    <TextView
        android:id="@+id/tvStatus"
        android:text="⏸ Listo para conectar"
        android:textSize="16sp"
        android:gravity="center"
        android:textColor="#555"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="20dp"/>

    <Button
        android:id="@+id/btnConnect"
        android:text="🔵 Conectar D110"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:backgroundTint="#1565C0"
        android:textColor="#FFF"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnToggle"
        android:text="▶ Iniciar escucha"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:backgroundTint="#2E7D32"
        android:textColor="#FFF"
        android:textSize="16sp"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:text="🧪 Modo diagnóstico"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#8B3A0F"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="6dp"/>

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="10dp">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp">

            <TextView
                android:text="Ancho (mm)"
                android:textSize="11sp"
                android:textColor="#888"/>

            <EditText
                android:id="@+id/etAncho"
                android:text="12"
                android:inputType="numberDecimal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp">

            <TextView
                android:text="Alto (mm)"
                android:textSize="11sp"
                android:textColor="#888"/>

            <EditText
                android:id="@+id/etAlto"
                android:text="20"
                android:inputType="numberDecimal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="10dp">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp">

            <TextView
                android:text="Letra código (px, 0=auto)"
                android:textSize="11sp"
                android:textColor="#888"/>

            <EditText
                android:id="@+id/etFuenteCodigo"
                android:text="0"
                android:inputType="numberDecimal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp">

            <TextView
                android:text="Letra nombre (px, 0=auto)"
                android:textSize="11sp"
                android:textColor="#888"/>

            <EditText
                android:id="@+id/etFuenteNombre"
                android:text="0"
                android:inputType="numberDecimal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="10dp">

        <Button
            android:id="@+id/btnGuardar"
            android:text="💾 Guardar"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:backgroundTint="#455A64"
            android:textColor="#FFF"
            android:textSize="12sp"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnPreview"
            android:text="👁 Vista previa"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:backgroundTint="#5D4037"
            android:textColor="#FFF"
            android:textSize="12sp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnTest"
            android:text="🧪 Imprimir"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:backgroundTint="#8B3A0F"
            android:textColor="#FFF"
            android:textSize="12sp"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

    <TextView
        android:text="Vista previa (aproximada, ya rotada como sale impresa):"
        android:textSize="11sp"
        android:textColor="#888"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="4dp"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#EFEFEF"
        android:padding="8dp"
        android:layout_marginBottom="14dp">

        <ImageView
            android:id="@+id/ivPreview"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:scaleType="fitCenter"
            android:background="#FFFFFF"
            android:contentDescription="Vista previa de la etiqueta"/>
    </FrameLayout>

    <TextView
        android:text="Log:"
        android:textSize="13sp"
        android:textColor="#888"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <TextView
            android:id="@+id/tvLog"
            android:text=""
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textColor="#333"
            android:padding="10dp"
            android:background="#F5F5F5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </ScrollView>

</LinearLayout>
