<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FFF8F0">

    <TextView
        android:text="📠 Niimbot Barro Tal Ves"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#8B3A0F"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="12dp"/>

    <TextView
        android:id="@+id/tvStatus"
        android:text="⏸ Listo para conectar"
        android:textSize="16sp"
        android:gravity="center"
        android:textColor="#555"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="20dp"/>

    <Button
        android:id="@+id/btnConnect"
        android:text="🔵 Conectar D110"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:backgroundTint="#1565C0"
        android:textColor="#FFF"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnToggle"
        android:text="▶ Iniciar escucha"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:backgroundTint="#2E7D32"
        android:textColor="#FFF"
        android:textSize="16sp"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:text="🧪 Modo diagnóstico"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#8B3A0F"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="6dp"/>

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="10dp">

        <EditText
            android:id="@+id/etAncho"
            android:text="12"
            android:hint="Ancho mm"
            android:inputType="numberDecimal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"/>

        <EditText
            android:id="@+id/etAlto"
            android:text="20"
            android:hint="Alto mm"
            android:inputType="numberDecimal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"/>
    </LinearLayout>

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="16dp">

        <Button
            android:id="@+id/btnGuardar"
            android:text="💾 Guardar tamaño"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:backgroundTint="#455A64"
            android:textColor="#FFF"
            android:textSize="13sp"
            android:layout_marginEnd="6dp"/>

        <Button
            android:id="@+id/btnTest"
            android:text="🧪 Imprimir TEST"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:backgroundTint="#8B3A0F"
            android:textColor="#FFF"
            android:textSize="13sp"
            android:layout_marginStart="6dp"/>
    </LinearLayout>

    <TextView
        android:text="Log:"
        android:textSize="13sp"
        android:textColor="#888"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <TextView
            android:id="@+id/tvLog"
            android:text=""
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textColor="#333"
            android:padding="10dp"
            android:background="#F5F5F5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </ScrollView>

</LinearLayout>
